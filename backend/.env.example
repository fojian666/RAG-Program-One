APP_NAME=agentic-image-rag
ENVIRONMENT=local
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/agentic_image_rag
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=images

# Aliyun Bailian (OpenAI-compatible endpoint)
# One API key works for LLM + Vision + Embedding
LLM_API_KEY=sk-d2b4d015185941aebfee94730ce7d703
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60

# Vision (Qwen-VL on Bailian)
VISION_API_KEY=sk-d2b4d015185941aebfee94730ce7d703
VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_MODEL=qwen-vl-max

# Text Embedding (Bailian)
EMBEDDING_API_KEY=sk-d2b4d015185941aebfee94730ce7d703
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIMENSIONS=1024

# Local SigLIP model path (optional, for local image embedding)
# Recommended for 10k+ images to save API cost
SIGLIP_MODEL_PATH=

# Ingestion concurrency for large-scale batch processing
INGESTION_CONCURRENCY=8
INGESTION_MAX_RETRIES=3
